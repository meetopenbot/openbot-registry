  "channels": [
    {
      "id": "website",
      "name": "Build Website",
      "description": "Create website",
      "spec": "Goal: Design, build, and deploy a professional, minimalist website.\n\n## Channel specific guidelines\n- Design UI screens via Stitch agent. Stitch returns HTML download URLs when generating or accessing existing screens. When delegating to Stitch, provide the user's name so it will be more personalized.\n- When designing UI screens, create only a single landing page with minimalist styling.\n- Build those screens via Claude Code (the HTML URLs can be provided to Claude so it can download and follow the design exactly).\n- GitHub agent can create a new repository.\n- OpenBot or Claude can execute git commands via a bash tool.\n- Vercel can deploy the website by providing the GitHub repository URL once the repository is created and the code is pushed.",
      "initialState": {},
      "participants": ["stitch", "vercel", "claude-code", "github"],
      "starterPrompts": [
        { "label": "SaaS", "prompt": "Create a SaaS landing page..." },
        { "label": "Portfolio", "prompt": "Create a Portfolio website. @stitch can design UI. @claude-code can build it and @vercel deploy" }
      ]
    },
    {
      "id": "slides",
      "name": "Build Slides",
      "description": "Create slides",
      "spec": "",
      "initialState": {},
      "participants": ["claude-code", "stitch", "gamma-slides"],
      "starterPrompts": [
        { "label": "Pitch Deck", "prompt": "Create a SaaS landing page..." },
        { "label": "Presentation", "prompt": "Create a portfolio landing page..." },
        { "label": "Gamma Slides", "prompt": "Create a pitch deck via Gamma..." }
      ]
    },
    {
      "id": "video",
      "name": "Generate Video",
      "description": "Create videos",
      "spec": "",
      "initialState": {},
      "participants": ["firecrawl", "remotion"],
      "starterPrompts": [
        { "label": "Product Demo", "prompt": "Create a product demo video. @firecrawl agent can scapre the url and @remotion agent can be used to create and render the video" },
        { "label": "New Feature Introduction", "prompt": "Create a new feature introduction video. @firecrawl agent can scapre the url (if needed for blog post or other webpage data extraction) and @remotion agent can be used to create and render the video" }
      ]
